{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run web app (dev)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "revealProblems": "never",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "echo": true,
        "clear": false
      },
      "problemMatcher": {
        "owner": "node",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Ready in|compiled|started server on|Local:|listening"
        }
      }
    }
  ]
}
