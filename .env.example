# Server-side env vars. Copy to .env and fill in.
# On Vercel, set these in the project settings instead.

# FIT ČVUT OAuth (register the app at https://auth.fit.cvut.cz/manager/)
FIT_OAUTH_CLIENT_ID=
FIT_OAUTH_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered in AppsManager.
# Dev with Vite proxy: http://localhost:5173/api/auth/fit/callback
# Dev without Vite (npm start):   http://localhost:3001/api/auth/fit/callback
# Production: https://<your-domain>/api/auth/fit/callback
FIT_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/fit/callback

# Supabase admin (used to mint a magic-link token after FIT login).
# SUPABASE_URL is the same value as client's VITE_SUPABASE_URL.
# SERVICE_ROLE_KEY is from Supabase dashboard → Project Settings → API.
# NEVER expose SERVICE_ROLE_KEY to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
